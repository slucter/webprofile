# ============================================================
# Salin file ini jadi .env.local untuk development.
# Di Vercel: isi nilainya lewat Project Settings > Environment Variables.
# JANGAN pernah commit .env.local — sudah diabaikan di .gitignore.
# ============================================================

# API key dari https://resend.com (gratis untuk volume kecil).
RESEND_API_KEY=

# Alamat pengirim. Domainnya WAJIB sudah diverifikasi di Resend,
# kalau tidak, email akan ditolak.
# Contoh: noreply@irhash.my.id
CONTACT_FROM_EMAIL=

# Tujuan pesan dari form. Kosongkan untuk memakai email di profile.ts.
CONTACT_TO_EMAIL=dev.irhashdianto@gmail.com
